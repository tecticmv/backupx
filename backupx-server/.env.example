# BackupX Server Configuration
# Copy this file to .env and update the values
# IMPORTANT: Never commit .env to version control!

# =============================================================================
# SECURITY CONFIGURATION (REQUIRED - Change these before production!)
# =============================================================================

# Secret key for session encryption and credential encryption
# CRITICAL: This key is used to encrypt all stored credentials in the database.
# If you change this key, all existing encrypted credentials will become unreadable!
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-secure-random-string

# Admin credentials
# IMPORTANT: Use a strong, unique password (minimum 12 characters recommended)
# Consider using: openssl rand -base64 24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
# Use INFO or WARNING in production
LOG_LEVEL=INFO

# Timezone for backup scheduling
TZ=UTC

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type: 'sqlite' (default) or 'postgresql'
DATABASE_TYPE=sqlite

# SQLite settings (only if DATABASE_TYPE=sqlite)
DATABASE_PATH=/app/data/backupx.db

# PostgreSQL settings (only if DATABASE_TYPE=postgresql)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=backupx
# DATABASE_USER=backupx
# DATABASE_PASSWORD=your-secure-password
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# DATABASE_SSL_MODE=prefer

# =============================================================================
# AUDIT LOGGING
# =============================================================================

# Enable audit logging (tracks all CRUD operations and login events)
AUDIT_ENABLED=true

# Number of days to retain audit logs (default: 90)
AUDIT_RETENTION_DAYS=90

# Log READ operations (verbose, disabled by default)
AUDIT_LOG_READS=false

# =============================================================================
# SESSION STORAGE (for horizontal scaling)
# =============================================================================

# Session storage type: 'filesystem' (default) or 'redis'
SESSION_TYPE=filesystem

# Filesystem session settings
SESSION_FILE_DIR=/app/data/sessions

# =============================================================================
# REDIS CONFIGURATION (required if SESSION_TYPE=redis)
# =============================================================================

# Redis is used for:
# - Session storage (horizontal scaling)
# - Rate limiting (distributed)
# - Optional: Distributed locking

# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_SSL=false
# REDIS_SESSION_DB=0
# REDIS_RATE_LIMIT_DB=1

# =============================================================================
# SCHEDULER CONFIGURATION
# =============================================================================

# Scheduler mode: 'standalone' (default) or 'distributed'
# - standalone: Uses APScheduler, single instance only
# - distributed: Database-backed with leader election, supports multiple instances
SCHEDULER_MODE=standalone

# Unique instance ID (auto-generated if not set)
# Useful for identifying instances in logs when running multiple
# INSTANCE_ID=

# =============================================================================
# RATE LIMITING
# =============================================================================

# Rate limiting is enabled by default:
# - Login: 5 attempts per minute
# - General API: 200 requests per day, 50 per hour
# When Redis is configured, rate limits are shared across instances.

# =============================================================================
# NOTES
# =============================================================================

# 1. All credentials stored in the database (S3 keys, database passwords,
#    restic passwords, agent API keys) are encrypted using the SECRET_KEY.
#
# 2. For production deployments:
#    - Use HTTPS via a reverse proxy (nginx, traefik, etc.)
#    - Set strong passwords and secret keys
#    - Review DEPLOYMENT.md for security recommendations
#
# 3. Backup your SECRET_KEY securely - losing it means losing access to
#    all encrypted credentials in the database.
#
# 4. For horizontal scaling (multiple instances):
#    - Set DATABASE_TYPE=postgresql
#    - Set SESSION_TYPE=redis
#    - Set SCHEDULER_MODE=distributed
#    - All instances share the same database and Redis
