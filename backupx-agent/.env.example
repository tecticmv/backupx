# BackupX Agent Configuration

# REQUIRED: API key for authentication (generate with: openssl rand -hex 32)
AGENT_API_KEY=your-secure-api-key-here

# Agent name (displayed in BackupX UI)
AGENT_NAME=my-server-agent

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Restrict backup paths (comma-separated)
# Leave empty to allow all mounted paths
# Example: ALLOWED_PATHS=/var/www,/home,/etc
ALLOWED_PATHS=
